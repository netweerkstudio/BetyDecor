---
import '../styles/global.css';
import Navbar from '../components/Navbar';
import WhatsappButton from '../components/WhatsappButton';
import Contact from '../components/Contact';
import Footer from '../components/Footer';
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="L'agence BetyDecor spécialisée en design d'intérieur à Tanger. Transformez votre espace résidentiel ou commercial avec notre approche créative sur mesure." />
    <meta name="keywords" content="design d'intérieur Tanger, agence design Tanger, BetyDecor, aménagement intérieur" />
    <title>Design d'Intérieur à Tanger | BetyDecor</title>
    <meta property="og:title" content="Design d'Intérieur à Tanger | BetyDecor" />
    <meta property="og:description" content="L'agence BetyDecor spécialisée en design d'intérieur à Tanger. Transformez votre espace résidentiel ou commercial avec notre approche créative sur mesure." />
    <meta property="og:image" content="https://betydecor.com/images/reception.jpg" />
    <meta property="og:url" content="https://betydecor.com/design-interieur-tanger" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="BetyDecor" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="icon" type="image/png" href="/logo/BetyDecor-Logo-Transparent.png" />
  </head>
  <body>
    <WhatsappButton client:load />
    <Navbar client:load />

    <div class="SeoHero" style="background: linear-gradient(to right, rgba(31,31,31,0.9), rgba(31,31,31,0.6)), url('/images/reception.jpg') no-repeat center center / cover;">
      <div class="SeoHeroContainer animate">
        <h1>Design d'Intérieur à Tanger</h1>
        <p>Découvrez notre agence BetyDecor, votre partenaire de confiance pour des projets de design d'intérieur à Tanger. De la conception à la réalisation, nous sublimons vos espaces de vie et de travail.</p>
        <div class="button">
          <a href="#contact">Demander un devis</a>
        </div>
      </div>
    </div>

    <div class="SeoContent">
      <div class="SeoContentContainer animate">
        <div class="textContent">
          <h2 class="title">Votre projet de design d'intérieur à Tanger avec BetyDecor</h2>
          <p>
            Tanger est une ville vibrante où le design moderne rencontre l'artisanat traditionnel. Notre agence maîtrise parfaitement cet équilibre pour vous proposer un design d'intérieur sur mesure, esthétique et hautement fonctionnel.
          </p>
          <ul>
            <li><i class="fa-solid fa-check"></i> Étude personnalisée de votre espace</li>
            <li><i class="fa-solid fa-check"></i> Création de concepts et visualisations 3D</li>
            <li><i class="fa-solid fa-check"></i> Aménagement complet (maison, appartement, commerce)</li>
            <li><i class="fa-solid fa-check"></i> Suivi minutieux des travaux à Tanger</li>
          </ul>
        </div>
        <div class="imageContent">
          <img src="/images/reception.jpg" alt="Design d'intérieur Tanger" />
        </div>
      </div>
    </div>

    <Contact client:load />
    <Footer client:load />
  </body>
</html>
